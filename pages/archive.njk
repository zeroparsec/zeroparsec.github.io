---
layout: base.njk
title: Archive
permalink: /archive/
---

<section class="archive">

  <div class="archive-header">
    <h1 class="archive-title">Archive</h1>
    <span class="archive-count">{{ collections.posts.length }} essays</span>
  </div>

  {% for group in collections.postsByYear %}
  <div class="archive-year-group">
    <h2 class="archive-year">{{ group.year }}</h2>
    <ol class="post-list archive-year-list">
      {% for post in group.posts %}
      <li class="post-item post-item--compact">
        <article>
          <div class="post-item-meta">
            <time datetime="{{ post.date | dateISO }}">{{ post.date | dateMonthDay }}</time>
          </div>
          <h3 class="post-item-title">
            <a href="{{ post.url }}">{{ post.data.title | titleCase }}</a>
          </h3>
          {% if post.data.description %}
          <p class="post-item-excerpt">{{ post.data.description }}</p>
          {% endif %}
        </article>
      </li>
      {% endfor %}
    </ol>
  </div>
  {% endfor %}

</section>
