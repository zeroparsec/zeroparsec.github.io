---
layout: base.njk
title: Essays
permalink: /essays/
---

<section class="archive">

  <div class="archive-header">
    <h1 class="archive-title">Essays</h1>
  </div>

  <ol class="post-list">
    {% for post in collections.posts %}
      {% if loop.index <= 5 %}
      <li class="post-item">
        <article>
          <div class="post-item-meta">
            <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay }}</time>
          </div>
          <h2 class="post-item-title">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h2>
          {% if post.data.description %}
          <p class="post-item-excerpt">{{ post.data.description }}</p>
          {% endif %}
        </article>
      </li>
      {% endif %}
    {% endfor %}
  </ol>

  {% if collections.posts.length > 5 %}
  <div class="archive-footer">
    <a href="/archive/" class="archive-all-link">All essays →</a>
  </div>
  {% endif %}

</section>
