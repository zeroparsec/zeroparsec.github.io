---
layout: base.njk
---

<article class="post">

  <header class="post-header">
    <div class="post-meta">
      <time datetime="{{ date | dateISO }}">{{ date | dateDisplay }}</time>
      <span class="meta-sep">·</span>
      <span>{{ content | readingTime }}</span>
    </div>
    <h1 class="post-title">{{ title }}</h1>
    {% if description %}
    <p class="post-subtitle">{{ description }}</p>
    {% endif %}
    <div class="post-rule"></div>
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <a href="/" class="back-link">← All essays</a>
  </footer>

</article>
